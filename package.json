{
  "name": "italian-brainrot-on-error",
  "displayName": "Italian Brainrot on Error",
  "description": "Speaks an Italian Brainrot character name out loud every time your code errors. Bombardiro Crocodillo has no mercy.",
  "version": "0.1.1",
  "publisher": "EkanshArora",
  "license": "MIT",
  "homepage": "https://github.com/Ekansh27/italian-brainrot-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ekansh27/italian-brainrot-vscode"
  },
  "bugs": {
    "url": "https://github.com/Ekansh27/italian-brainrot-vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "italian brainrot",
    "bombardiro crocodillo",
    "fun",
    "error",
    "sound",
    "notification",
    "meme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "italian-brainrot.testBrainrot",
        "title": "Italian Brainrot: Summon Character"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.x",
    "typescript": "^5.x"
  }
}
